{%- liquid
  assign categories_raw = section.settings.filter_categories
  assign categories = categories_raw | split: ','
  assign show_filters = section.settings.show_filters
  assign show_search = section.settings.show_search
  assign show_sort = section.settings.show_sort
  assign all_label = section.settings.filter_all_label
  if all_label == blank
    assign all_label = 'sections.main_collection.filter_all_label' | t
  endif

  assign total_count = collection.products_count
  assign noun = 'sections.main_collection.item_plural' | t
  if total_count == 1
    assign noun = 'sections.main_collection.item_singular' | t
  endif
  assign initial_count_text = 'sections.main_collection.item_count' | t: count: total_count, noun: noun
-%}

<section class="main-collection full-width" data-collection-root>
  <div class="main-collection__inner cham-container">
    <header class="main-collection__head" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="main-collection__heading font-display">
        {{- section.settings.heading_lead -}}
        {%- if section.settings.heading_emphasis != blank %} <em>{{ section.settings.heading_emphasis }}</em>{%- endif -%}
        {%- if section.settings.heading_tail != blank -%}{{ section.settings.heading_tail }}{%- endif -%}
      </h1>
      {%- if section.settings.body != blank -%}
        <div class="main-collection__body">{{ section.settings.body }}</div>
      {%- endif -%}
    </header>
{%- if collection.products_count > 0 -%}
  {%- if show_search or show_sort -%}
  <div class="main-collection__toolbar" data-reveal data-reveal-delay="80">
  {%- if show_search -%}
  <form class="main-collection__search" role="search" action="{{ routes.search_url }}" method="get">
  <input type="hidden" name="type" value="product">
  <label class="main-collection__visually-hidden" for="CollectionSearch">Search products</label>
  <input type="search" name="q" id="CollectionSearch" class="main-collection__search-input" placeholder="Search products&#8230;" value="">
  <button type="submit" class="main-collection__search-submit" aria-label="Search">Search</button>
  </form>
  {%- endif -%}
  {%- if show_sort -%}
  <form class="main-collection__sort" action="{{ request.path }}" method="get" data-collection-sort-form>
  <label class="main-collection__visually-hidden" for="CollectionSortBy">Sort by</label>
  <select name="sort_by" id="CollectionSortBy" class="main-collection__sort-select" data-collection-sort>
  <option value="manual" {% if collection.sort_by == blank or collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
  <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Most Popular</option>
  <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
  <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
  <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
  </select>
  <button type="submit" class="main-collection__visually-hidden">Apply sort</button>
  </form>
  {%- endif -%}
  </div>
  {%- endif -%}
    {%- if show_filters and collection.products_count > 0 -%}
      <div class="main-collection__filter-bar" data-reveal data-reveal-delay="100">
        <div class="main-collection__filters" role="tablist" aria-label="Filter by category">
          <button
            type="button"
            class="main-collection__filter is-active"
            data-filter
            data-filter-value="all"
            role="tab"
            aria-selected="true"
          >{{ all_label }}</button>
          {%- for cat in categories -%}
            {%- assign cat_trimmed = cat | strip -%}
            {%- if cat_trimmed != blank -%}
              <button
                type="button"
                class="main-collection__filter"
                data-filter
                data-filter-value="{{ cat_trimmed | downcase | escape }}"
                role="tab"
                aria-selected="false"
              >{{ cat_trimmed }}</button>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <span
          class="main-collection__count"
          data-collection-count
          data-singular="{{ 'sections.main_collection.item_singular' | t }}"
          data-plural="{{ 'sections.main_collection.item_plural' | t }}"
        >{{ initial_count_text }}</span>
      </div>
    {%- endif -%}
  {%- endif -%}
    {%- if collection.products_count > 0 -%}
      <div class="main-collection__grid" data-collection-grid>
        {%- paginate collection.products by 250 -%}
              {%- for product in collection.products -%}
          {%- liquid
            # Build a space-separated list of all categories this product belongs to.
            # Categories are collected from three sources, all lowercased:
            #   1. Tags starting with "category:" (e.g. "category:face") → "face"
            #      Tags also match the plain category name (e.g. tag "Face" → "face")
            #   2. The custom.category metafield (single string OR list of strings)
            #   3. The built-in Product type
            # A product can match multiple categories — useful for "face and body" items.

                  assign cat_list = ''

                        # --- Category matching based on Shopify's real Product Category (taxonomy) ---
                              # Falls back to Product Type when Category is blank.
                                    # Many raw taxonomy category names are merged into a smaller, friendlier set
                                          # of filter labels (defined in the section's filter_categories setting).
                                                assign raw_category = ''
                                                      if product.category
                                                              assign raw_category = product.category.name
                                                                    endif
                                                                          if raw_category == blank and product.type != blank
                                                                                  assign raw_category = product.type
                                                                                        endif
                                                                                              assign raw_category_lower = raw_category | downcase | strip

                                                                                                    case raw_category_lower
                                                                                                            when 'face moisturizers', 'face primers'
                                                                                                                      assign cat_list = 'face moisturizers'
                                                                                                                              when 'facial cleansers', 'makeup removers'
                                                                                                                                        assign cat_list = 'facial cleansers'
                                                                                                                                                when 'sunscreen'
                                                                                                                                                          assign cat_list = 'sunscreen'
                                                                                                                                                                  when 'lotions & moisturizers', 'body balms', 'hand creams', 'anti-perspirant'
                                                                                                                                                                            assign cat_list = 'body care'
                                                                                                                                                                                    when 'face serums'
                                                                                                                                                                                              assign cat_list = 'face serums'
                                                                                                                                                                                                      when 'eye creams'
                                                                                                                                                                                                                assign cat_list = 'eye creams'
                                                                                                                                                                                                                        when 'toners'
                                                                                                                                                                                                                                  assign cat_list = 'toners'
                                                                                                                                                                                                                                          when 'anti-aging skin care'
                                                                                                                                                                                                                                                    assign cat_list = 'anti-aging skin care'
                                                                                                                                                                                                                                                            when 'skin care masks & peels'
                                                                                                                                                                                                                                                                      assign cat_list = 'skin care masks & peels'
                                                                                                                                                                                                                                                                              when 'acne treatments & kits', 'acne spot treatments'
                                                                                                                                                                                                                                                                                        assign cat_list = 'acne treatments'
                                                                                                                                                                                                                                                                                                when 'lip balms'
                                                                                                                                                                                                                                                                                                          assign cat_list = 'lip balms'
                                                                                                                                                                                                                                                                                                                  when 'body wash', 'bar soap'
                                                                                                                                                                                                                                                                                                                            assign cat_list = 'body wash & soap'
                                                                                                                                                                                                                                                                                                                                    else
                                                                                                                                                                                                                                                                                                                                              assign cat_list = raw_category_lower
                                                                                                                                                                                                                                                                                                                                                    endcase

            assign eager = false
            if forloop.index0 < 3
              assign eager = true
            endif
          -%}
          <div
            class="main-collection__item"
            data-collection-item
            data-categories="{{ cat_list | escape }}"
                                                                                                  data-reveal
            data-reveal-delay="{{ forloop.index0 | times: 80 }}"
          >
            {%- render 'product-card', product: product, eager: eager -%}
          </div>
        {%- endfor -%}
      {%- endpaginate -%}
      </div>
    {%- else -%}
      <p class="main-collection__empty">{{ 'sections.main_collection.no_products' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .main-collection {
    width: 100%;
    padding-top: calc(var(--header-height) + 4rem);
    padding-bottom: 8rem;
  }

  @media (min-width: 1024px) {
    .main-collection {
      padding-top: calc(var(--header-height) + 6rem);
      padding-bottom: 10rem;
    }
  }

  .main-collection__head {
    max-width: 48rem;
  }

  .main-collection__heading {
    margin-top: 1.5rem;
    font-size: 3rem;
    line-height: 0.98;
  }

  @media (min-width: 1024px) {
    .main-collection__heading {
      font-size: 6rem;
    }
  }

  .main-collection__heading em {
    color: var(--primary);
    font-style: italic;
  }

  .main-collection__body {
    margin-top: 2rem;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
    line-height: 1.65;
    max-width: 36rem;
  }

  .main-collection__body > p {
    margin: 0;
  }

  .main-collection__filter-bar {
    margin-top: 4rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  @media (min-width: 1024px) {
    .main-collection__filter-bar {
      margin-top: 6rem;
    }
  }

  .main-collection__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .main-collection__filter {
    padding: 0.5rem 1.25rem;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    border: 1px solid var(--border);
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
    background-color: transparent;
    cursor: pointer;
    transition: border-color 0.3s ease, color 0.3s ease, background-color 0.3s ease;
  }

  .main-collection__filter:hover,
  .main-collection__filter:focus-visible {
    border-color: var(--primary);
    color: var(--primary);
  }

  .main-collection__filter.is-active {
    background-color: var(--primary);
    border-color: var(--primary);
    color: var(--primary-foreground);
  }

  .main-collection__count {
    margin-left: auto;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--muted-foreground);
  }

  .main-collection__grid {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: 1fr;
    column-gap: 2rem;
    row-gap: 4rem;
  }

  @media (min-width: 768px) {
    .main-collection__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .main-collection__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .main-collection__item[data-hidden="true"] {
    display: none;
  }

  .main-collection__empty {
    margin-top: 4rem;
    color: var(--muted-foreground);
    font-size: 0.875rem;
  }

  .main-collection__toolbar {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .main-collection__search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1 1 16rem;
    max-width: 24rem;
    border: 1px solid var(--border);
    padding: 0.625rem 0.875rem;
  }

  .main-collection__search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 0.875rem;
    color: var(--foreground);
    outline: none;
  }

  .main-collection__search-input::placeholder {
    color: var(--muted-foreground);
  }

  .main-collection__search-submit {
    border: none;
    background: transparent;
    cursor: pointer;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
    transition: color 0.3s ease;
  }

  .main-collection__search-submit:hover,
  .main-collection__search-submit:focus-visible {
    color: var(--primary);
  }

  .main-collection__sort-select {
    border: 1px solid var(--border);
    background-color: transparent;
    color: var(--foreground);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 0.6875rem 1rem;
    cursor: pointer;
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .main-collection__sort-select:hover,
  .main-collection__sort-select:focus-visible {
    border-color: var(--primary);
    color: var(--primary);
  }

  .main-collection__visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[data-collection-root]').forEach((root) => {
      if (root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      const filters = root.querySelectorAll('[data-filter]');
      const items = root.querySelectorAll('[data-collection-item]');
      const counter = root.querySelector('[data-collection-count]');
      if (!filters.length || !items.length) return;

      const singular = counter ? counter.getAttribute('data-singular') || 'item' : 'item';
      const plural = counter ? counter.getAttribute('data-plural') || 'items' : 'items';

      function applyFilter(value) {
        let visible = 0;
        items.forEach((item) => {
          // Each item carries a comma-separated list of categories it belongs to,
                    // already lowercased server-side. A product matches a filter if the
                              // filter value appears as one of those comma-separated entries.
          const catsAttr = item.getAttribute('data-categories') || '';
const cats = catsAttr.split(',').map(s => s.trim()).filter(Boolean);
          const match = value === 'all' || cats.indexOf(value) !== -1;
          if (match) {
            item.removeAttribute('data-hidden');
            visible += 1;
          } else {
            item.setAttribute('data-hidden', 'true');
          }
        });
        if (counter) {
          counter.textContent = visible + ' ' + (visible === 1 ? singular : plural);
        }
      }

      filters.forEach((btn) => {
        btn.addEventListener('click', () => {
          const value = btn.getAttribute('data-filter-value');
          filters.forEach((b) => {
            const isActive = b === btn;
            b.classList.toggle('is-active', isActive);
            b.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });
          applyFilter(value);
        });
      });
      const sortSelect = root.querySelector('[data-collection-sort]');
      if (sortSelect) {
        sortSelect.addEventListener('change', () => {
          const form = sortSelect.closest('form');
          if (form) form.submit();
        });
      }

    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.main_collection.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "heading_lead",
      "label": "t:labels.heading_lead",
      "default": "Formulations"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "t:labels.heading_emphasis",
      "default": "for skin that performs"
    },
    {
      "type": "text",
      "id": "heading_tail",
      "label": "Heading (after emphasis)",
      "default": "."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:labels.body",
      "default": "<p>Each product activates a specific skin function. Together, they create visible brightness, smoother texture and long-term glow.</p>"
    },
    {
      "type": "header",
      "content": "Filters"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "t:labels.show_filters",
      "default": true
    },

    {
    "type": "checkbox",
    "id": "show_search",
    "label": "Show search bar",
    "default": true
    },
    {
    "type": "checkbox",
    "id": "show_sort",
    "label": "Show sort dropdown",
    "default": true
    },
    {
      "type": "text",
      "id": "filter_categories",
      "label": "t:labels.filter_categories",
      "info": "Comma-separated. Assign each product to a category using any of: tag (e.g. 'category:face' or just 'Face'), the custom.category metafield (single or list), or the Product type field.",
      "default": "Face, Body, Treatment"
    },
    {
      "type": "text",
      "id": "filter_all_label",
      "label": "'All' pill label",
      "default": "All"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
